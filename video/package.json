{
  "name": "educal-promo-video",
  "version": "1.0.0",
  "description": "Educal Promo Video",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.446",
    "@remotion/media": "^4.0.446",
    "@remotion/tailwind-v4": "4.0.446",
    "@remotion/transitions": "^4.0.446",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.446",
    "tailwindcss": "4.0.0"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.446",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "render": "remotion render src/index.ts AppPromo out/educal-promo.mp4",
    "render-reverse": "remotion render src/index.ts AppPromoReverse out/educal-promo-reverse.mp4",
    "slide-build": "remotion still src/index.ts BackupSlide-Build out/educal-slide-build.png",
    "slide-reflect": "remotion still src/index.ts BackupSlide-Reflect out/educal-slide-reflect.png",
    "slide-hero": "remotion still src/index.ts BackupSlide-Hero out/educal-slide-hero.png",
    "slides": "bun run slide-build && bun run slide-reflect && bun run slide-hero",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc"
  },
  "sideEffects": [
    "*.css"
  ]
}
